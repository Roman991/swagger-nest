{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "src",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "tsc",
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.json"
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "src",
      "entryFile": "src/main",
      "sourceRoot": "src",
      "compilerOptions": {
        "assets": [
          {
            "include": "docker-compose.yml",
            "outDir": "dist/api"
          },
          {
            "include": "package.json",
            "outDir": "dist/api"
          }
        ],
        "plugins": [
          {
            "name": "@nestjs/swagger",
            "options": {
              "introspectComments": true,
              "dtoFileNameSuffix": [".dto.ts", ".entity.ts", ".model.ts"]
            }
          }
        ]
      }
    }
  }
}
